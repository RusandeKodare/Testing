{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "*": ["../*"]
    }
  },
  "include": ["backend/**/*", "frontend/**/*", "../backend/src/**/*", "../frontend/src/**/*"],
  "exclude": ["node_modules"]
}
